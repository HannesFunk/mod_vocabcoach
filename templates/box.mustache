{{!
    @template mod_vocabcoach/box

    Renders a single vocab box item inside the boxdata loop in view.mustache.

    Example context (json):
    {
        "stage": 2,
        "due": 5,
        "total": 18,
        "status": "todo",
        "nextdue": "Jetzt"
    }
}}
<div
        class="box {{status}}"
        data-due="{{due}}"
        data-total="{{total}}"
        data-stage="{{stage}}"
        data-action="mod_vocabcoach/check_box"
        data-next-due="{{nextdue}}"
>
    <div class="box-top-line">
        <div class="box-title mr-2">{{#str}}view_box_title, mod_vocabcoach, {{stage}}{{/str}}</div>
        <div class="dropdown">
            <a href="#" class="btn btn-link btn-icon colour-inherit text-decoration-none d-flex align-items-center justify-content-center" role="button" data-bs-toggle="dropdown" data-boundary="window" aria-haspopup="true" tabindex="0" aria-controls="box-{{stage}}-menu" aria-label="{{#str}}view_show_actions, mod_vocabcoach{{/str}}" aria-expanded="false">
                <i class="fa fa-ellipsis-v text-white py-2" aria-hidden="true"></i>
            </a>
            <div
                    class="dropdown-menu dropdown-menu-right"
                    aria-labelledby="box-{{stage}}-menu"
                    data-rel="menu-content"
                    role="menu"
                    id="box-{{stage}}-menu">
                <a
                        class="dropdown-item menu-action {{#due}}disabled{{/due}}"
                        role="menuitem"
                        tabindex="-1"
                        data-targetstate="0"
                        title="{{#str}}view_check_undue, mod_vocabcoach{{/str}}"
                        href="#"
                        data-action="mod_vocabcoach/force_check_all"
                >
                    <i class="fa fa-question-circle-o pr-2" aria-hidden="true"></i>
                    <span class="menu-action-text">{{#str}}view_check_undue, mod_vocabcoach{{/str}}</span>
                </a>
                <a
                        class="dropdown-item menu-action"
                        role="menuitem"
                        tabindex="-1"
                        data-targetstate="0"
                        data-stage="{{stage}}"
                        title="{{#str}}view_remove_incorrect, mod_vocabcoach{{/str}}"
                        href="#"
                        data-action="mod_vocabcoach/view_box"
                >
                    <i class="fa fa-edit pr-2" aria-hidden="true"></i>
                    <span class="menu-action-text">{{#str}}view_remove_incorrect, mod_vocabcoach{{/str}}</span>
                </a>
                <a
                        class="dropdown-item menu-action"
                        role="menuitem"
                        tabindex="-1"
                        data-targetstate="0"
                        data-stage="{{stage}}"
                        title="{{#str}}view_export_pdf, mod_vocabcoach{{/str}}"
                        href="#"
                        data-action="mod_vocabcoach/show_pdf_user"
                >
                    <i class="fa fa-copy pr-2" aria-hidden="true"></i>
                    <span class="menu-action-text">{{#str}}view_export_pdf, mod_vocabcoach{{/str}}</span>
                </a>
            </div>
        </div>
    </div>
    <div class="box-bottom-line">
        <span class="box-numbers">{{due}} / {{total}}</span>
    </div>
</div>