<div class="dropdown">
    <a href="#" class="btn btn-link btn-icon colour-primary text-decoration-none d-flex ml-auto" role="button" data-bs-toggle="dropdown" data-bs-boundary="window" aria-haspopup="true" tabindex="0" aria-controls="list-{{id}}-menu" aria-label="{{#str}}actions_show_actions, mod_vocabcoach{{/str}}" aria-expanded="false">
        <i class="fa fa-ellipsis-h text-dark  py-2" aria-hidden="true"></i>
    </a>
    <div class="dropdown-menu dropdown-menu-right"
            aria-labelledby="list-{{id}}-menu"
            data-rel="menu-content"
            role="menu">
        <a class="dropdown-item menu-action"
                role="menuitem"
                tabindex="-1"
                title="{{#str}} edit {{/str}}"
                href="#"
                data-action="mod_vocabcoach/edit-vocab">
            <i class="fa fa-edit  pr-2" aria-hidden="true"></i>
            <span class="menu-action-text">{{#str}} edit {{/str}}</span>
        </a>
        <a class="dropdown-item menu-action"
                role="menuitem"
                tabindex="-1"
                title="{{#str}} delete {{/str}}"
                href="#"
                data-list-id="{{id}}"
                data-action="mod_vocabcoach/delete-vocab">
            <i class="fa fa-trash  pr-2" aria-hidden="true"></i>
            <span class="menu-action-text">{{#str}} delete {{/str}}</span>
        </a>

    </div>
</div>
