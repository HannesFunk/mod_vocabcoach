{{!
    @template mod_vocabcoach/viewbox

    Example context (json):
    {
        "fronttitle": "Englisch",
        "backtitle": "Deutsch",
        "vocabs": [
            {
                "front": "apple",
                "back": "Apfel",
                "dataid": 123
            }
        ]
    }
}}
<table id="table-list" class="table generaltable">
    <tbody>
    <tr>
        <th>{{fronttitle}}</th>
        <th>{{backtitle}}</th>
        <th></th>
    </tr>
    {{#vocabs}}
        <tr>
            <td>{{front}}</td>
            <td>{{back}}</td>
            <td>
                <button
                    type="button"
                    class="btn btn-secondary mb-1"
                    data-action="mod_vocabcoach/remove_vocab_from_user"
                    data-dataid="{{dataid}}"
                >
                    {{#str}} remove_from_box, mod_vocabcoach {{/str}}
                </button>
            </td>
        </tr>
    {{/vocabs}}
    </tbody>
</table>

